def longest_subarray_with_zero_sum_detailed(arr):
    # Hash map to store first occurrence of each prefix sum
    prefix_sum_map = {}
    prefix_sum = 0
    max_length = 0
    
    print("Step-by-step trace:")
    print("Index | Element | Prefix Sum | Map State | Max Length")
    print("-" * 50)
    
    for i in range(len(arr)):
        # Calculate prefix sum
        prefix_sum += arr[i]
        print(f"{i:5} | {arr[i]:7} | {prefix_sum:10} | {prefix_sum_map} | {max_length}")
        
        # If prefix sum is 0, the subarray from index 0 to i has sum 0
        if prefix_sum == 0:
            max_length = i + 1
            print(f"  -> Prefix sum is 0, max_length updated to {max_length}")
        
        # If this prefix sum was seen before, update max_length
        elif prefix_sum in prefix_sum_map:
            length = i - prefix_sum_map[prefix_sum]
            max_length = max(max_length, length)
            print(f"  -> Prefix sum {prefix_sum} seen before at index {prefix_sum_map[prefix_sum]}, subarray length = {length}, max_length = {max_length}")
        
        # If this is the first occurrence of the prefix sum, store it
        else:
            prefix_sum_map[prefix_sum] = i
            print(f"  -> Storing prefix sum {prefix_sum} at index {i}")
    
    print(f"Final result: {max_length}")
    return max_length

# Test with the given example
arr = [1, -1, 3, 2, -2, -3, 3]
result = longest_subarray_with_zero_sum_detailed(arr)
