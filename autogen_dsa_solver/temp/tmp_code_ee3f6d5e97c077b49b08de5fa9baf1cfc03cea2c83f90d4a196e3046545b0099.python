for i, num in enumerate(nums):
    prev = num - k
    if prev in dp:
        dp[num] = dp[prev] + 1
        print(f"Index {i}: {num}, extended from {prev}, length = {dp[num]}")
    else:
        dp[num] = 1
        print(f"Index {i}: {num}, started new sequence, length = {dp[num]}")
    max_length = max(max_length, dp[num])
    print(f"  dp = {dp}")
    print(f"  max_length = {max_length}")

print(f"\nMaximum length found: {max_length}")

