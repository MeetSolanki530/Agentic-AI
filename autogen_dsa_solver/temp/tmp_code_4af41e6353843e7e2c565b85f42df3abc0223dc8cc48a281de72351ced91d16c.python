print("Starting the solution...")
def longestDuplicateSubstring(s):
    n = len(s)
    if n < 2:
        return ""
    
    char_index_map = {}
    max_length = 0
    result = ""
    
    for i in range(n):
        if s[i] in char_index_map:
            if (i - char_index_map[s[i]]) > max_length:
                max_length = i - char_index_map[s[i]]
                result = s[char_index_map[s[i]] : i+1]
            
        else:
            char_index_map[s[i]] = i
    
    return result

