code = '''
def add_numbers(a, b):
    """
    This function takes two numbers as input and returns their sum.
    """
    return a + b

# Example usage:
num1 = 5
num2 = 10
sum_result = add_numbers(num1, num2)
print(f"The sum of {num1} and {num2} is: {sum_result}")

num3 = -3
num4 = 7
sum_result_2 = add_numbers(num3, num4)
print(f"The sum of {num3} and {num4} is: {sum_result_2}")
'''

with open('solution.py','w') as f:
    f.write(code)
print("file saved")
