code = '''
def add_numbers(a, b):
  """
  This function takes two numbers and returns their sum.
  """
  return a + b

# Test the function
num1 = 5
num2 = 10
result = add_numbers(num1, num2)
print(f"The sum of {num1} and {num2} is: {result}")
'''

with open('solution.py','w') as f:
    f.write(code)
print("file saved")
