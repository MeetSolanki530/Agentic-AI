code = '''
def longest_subarray_with_zero_sum(arr):
    # Hash map to store first occurrence of each prefix sum
    prefix_sum_map = {}
    prefix_sum = 0
    max_length = 0
    
    for i in range(len(arr)):
        # Calculate prefix sum
        prefix_sum += arr[i]
        
        # If prefix sum is 0, the subarray from index 0 to i has sum 0
        if prefix_sum == 0:
            max_length = i + 1
        
        # If this prefix sum was seen before, update max_length
        elif prefix_sum in prefix_sum_map:
            max_length = max(max_length, i - prefix_sum_map[prefix_sum])
        
        # If this is the first occurrence of the prefix sum, store it
        else:
            prefix_sum_map[prefix_sum] = i
    
    return max_length

# Test with the given example
arr = [1, -1, 3, 2, -2, -3, 3]
result = longest_subarray_with_zero_sum(arr)
print(f"Input array: {arr}")
print(f"Length of longest subarray with sum 0: {result}")
'''

with open('solution.py', 'w') as f:
    f.write(code)
print("file saved")
