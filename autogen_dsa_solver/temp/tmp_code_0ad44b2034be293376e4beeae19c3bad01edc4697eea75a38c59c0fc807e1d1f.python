def longestSubsequenceWithDiffK(nums, k):
    # Dictionary to store the length of longest subsequence ending with value v
    dp = {}
    max_length = 1
    
    # Process each number in the array
    for num in nums:
        # For difference k, previous element in subsequence should be num-k
        prev = num - k
        if prev in dp:
            # We can extend the subsequence ending at prev
            dp[num] = dp[prev] + 1
        else:
            # Start a new subsequence with this number
            dp[num] = 1
        max_length = max(max_length, dp[num])
    
    return max_length

# Test cases where I know the answers
test_cases = [
    ([1, 3, 5, 7], 2, 4),  # Should be [1,3,5,7] = 4 elements
    ([1, 2, 3, 4], 1, 4),  # Should be [1,2,3,4] = 4 elements  
    ([7, 7, 7, 7], 0, 4),  # Should be [7,7,7,7] = 4 elements
    ([1, 5, 7, 8, 5, 3, 4, 2, 1], 2, 4) # The given example - should be 4 according to problem
]

print("Testing known cases:")
for nums, k, expected in test_cases:
    result = longestSubsequenceWithDiffK(nums, k)
    status = "✓" if result == expected else "✗"
    print(f"{status} Array: {nums}, k: {k}, Expected: {expected}, Got: {result}")

# Also testing edge cases
print("\nEdge case testing:")
print("Empty array:", longestSubsequenceWithDiffK([], 2))
print("Single element:", longestSubsequenceWithDiffK([5], 2))
print("All same elements:", longestSubsequenceWithDiffK([3, 3, 3], 0))

print("\nAlgorithm explanation:")
print("1. We use dynamic programming where dp[value] stores the length of longest")
print("   arithmetic subsequence ending with that value")
print("2. For each element, we check if (element - k) exists in our dp map")
print("3. If it does, we extend that subsequence by 1; otherwise we start a new one")
print("4. We track the maximum length seen so far")

# Save the final solution
code = '''
def longestSubsequenceWithDiffK(nums, k):
    """
    Find the length of the longest subsequence where the difference 
    between adjacent elements is exactly k.
    
    Args:
        nums: List of integers
        k: Target difference between adjacent elements
        
    Returns:
        Length of longest such subsequence
    """
    if not nums:
        return 0
        
    # Dictionary to store the length of longest subsequence ending with value v
    dp = {}
    max_length = 1
    
    # Process each number in the array
    for num in nums:
        # For difference k, previous element in subsequence should be num-k
        prev = num - k
        if prev in dp:
            # We can extend the subsequence ending at prev
            dp[num] = dp[prev] + 1
        else:
            # Start a new subsequence with this number
            dp[num] = 1
        max_length = max(max_length, dp[num])
    
    return max_length

# Test with the given example
nums = [1, 5, 7, 8, 5, 3, 4, 2, 1]
k = 2
result = longestSubsequenceWithDiffK(nums, k)
print(f"Length of longest subsequence with difference {k}: {result}")
'''

with open('solution.py', 'w') as f:
    f.write(code)
print("File saved")
