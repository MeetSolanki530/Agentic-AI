print("\nExpected path for subsequence [7,5,3,1] with k=2:")
print("  dp[7] = 1 (start)")
print("  When we see 5 (index 4), we look for 5-(-2) = 7, which is in dp, so dp[5] = dp[7] + 1 = 2")
print("  When we see 3 (index 5), we look for 3-(-2) = 5, which is in dp, so dp[3] = dp[5] + 1 = 3")
print("  When we see 1 (index 8), we look for 1-(-2) = 3, which is in dp, so dp[1] = dp[3] + 1 = 4")
print("  But we're looking for differences of exactly k=2, so we look for num-k not num-(-k)")

